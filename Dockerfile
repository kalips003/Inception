
#//////////////////////////////////////////////////////////////////////////////]
# OS or Runtime image
FROM debian:bookworm-slim

#//////////////////////////////////////////////////////////////////////////////]
# Where your application will live inside the container
WORKDIR

#//////////////////////////////////////////////////////////////////////////////]
# Bring your source code into the image
COPY

#//////////////////////////////////////////////////////////////////////////////]
# Install libraries, packages, tools your app needs
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

#//////////////////////////////////////////////////////////////////////////////]
# Optional: default settings
ENV

#//////////////////////////////////////////////////////////////////////////////]
# Optional: declare ports the app will use
EXPOSE

#//////////////////////////////////////////////////////////////////////////////]
# CMD or ENTRYPOINT - Defines PID 1 inside container
CMD ["bash"]
