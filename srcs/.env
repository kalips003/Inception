
### NGINX SETUP ###
DOMAIN_NAME=agallon.42.fr
NGINX_SSL_PRIVATE=/etc/ssl/private/nginx.key
NGINX_SSL_PUBLIC=/etc/ssl/certs/nginx.crt


### WORDPRESS SETUP ###
#Site/admin info
WP_TITLE=CAT
WP_ADMIN_USR=god
WP_ADMIN_PWD=
WP_ADMIN_EMAIL=god.real@gmail.com

WP_USR=another_cat
WP_EMAIL=cat.god2@gmail.com
WP_USR_PWD=

# DB credentials
DB_NAME= # → The name of the database WordPress will use.
DB_USER= # → The username WordPress will use to log in to that database.
DB_PWD= # → The password for that database user.
DB_HOST=mariadb


### MYSQL SETUP ###
SQL_FILE_PATH=/tmp/init.sql
DB_ROOT_PWD_PATH=/run/secrets/db_root_password
DB_PWD_PATH=/run/secrets/db_password

# 1. Initialize system tables (mysql, information_schema, performance_schema)
# 2. Create root user with MYSQL_ROOT_PASSWORD
MYSQL_ROOT_PASSWORD=
# 3. Optionally create a database named MYSQL_DATABASE
MYSQL_DATABASE=wordpress
# 4. Optionally create a user MYSQL_USER with MYSQL_PASSWORD
#	and grant it access to MYSQL_DATABASE
MYSQL_USER=agallon
MYSQL_PASSWORD=
# 5. Run any .sql or .sh files in /docker-entrypoint-initdb.d/