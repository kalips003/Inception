### MYSQL SETUP ###
SQL_FILE_PATH=/tmp/init.sql
DB_ROOT_PWD_PATH=/run/secrets/db_root_password
DB_PWD_PATH=/run/secrets/db_password

# 1. Initialize system tables (mysql, information_schema, performance_schema)
# 2. Create root user with MYSQL_ROOT_PASSWORD
MYSQL_ROOT_PASSWORD=
# 3. Optionally create a database named MYSQL_DATABASE
MYSQL_DATABASE=wordpress
# 4. Optionally create a user MYSQL_USER with MYSQL_PASSWORD
#	and grant it access to MYSQL_DATABASE
MYSQL_USER=agallon
MYSQL_PASSWORD=
# 5. Run any .sql or .sh files in /docker-entrypoint-initdb.d/